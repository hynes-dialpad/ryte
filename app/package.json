{
  "name": "ryte",
  "version": "0.1.0",
  "description": "Local search + read-only viewer for ~/notes/",
  "main": "./out/main/index.js",
  "author": "Joshua Hynes",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "rebuild:electron": "node_modules/.pnpm/node_modules/.bin/electron-rebuild -f -w better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "postinstall": "node_modules/.pnpm/node_modules/.bin/electron-rebuild -f -w better-sqlite3 || electron-builder install-app-deps",
    "build:unpack": "pnpm build && electron-builder --dir",
    "build:mac": "pnpm build && electron-builder --mac"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@shikijs/markdown-it": "^4.0.2",
    "@types/markdown-it": "^14.1.2",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^4.0.3",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "openai": "^4.77.0",
    "pinia": "^2.3.0",
    "shiki": "^4.0.2",
    "sqlite-vec": "^0.1.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.19.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-vue": "^10.6.2",
    "prettier": "^3.7.4",
    "tsx": "^4.22.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^2.1.8",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
